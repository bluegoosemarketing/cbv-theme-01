{% comment %}
  Section: Subscription Editorial
  Description: A premium landing page section designed specifically to merchandise subscriptions and the Candle Club.
{% endcomment %}

<style>
  /* CSS Reset & Scope Firewall */
  .cbv-subscription {
    --color-bg: {{ section.settings.bg_color }};
    --color-text: {{ section.settings.text_color }};
    --color-accent: {{ section.settings.accent_color }};
    --font-heading: var(--font-heading-family, "Playfair Display", Georgia, serif);
    --font-body: var(--font-body-family, "Helvetica Neue", Arial, sans-serif);
    
    background-color: var(--color-bg);
    color: var(--color-text);
    overflow: hidden;
    position: relative;
    font-size: 16px; 
    box-sizing: border-box;
  }

  .cbv-subscription * {
    box-sizing: border-box;
  }

  /* Reveal Animations */
  .reveal-up {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .reveal-up.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }

  /* Typography Reset */
  .cbv-subscription h1, 
  .cbv-subscription h2, 
  .cbv-subscription h3 {
    font-family: var(--font-heading);
    font-weight: 400;
    line-height: 1.15;
    color: currentColor;
    margin: 0 0 24px 0;
    letter-spacing: normal;
  }
  
  .cbv-subscription p {
    font-family: var(--font-body);
    line-height: 1.7;
    margin: 0 0 24px 0;
    font-size: clamp(16px, 1.2vw, 18px); 
    letter-spacing: 0.3px;
  }

  .cbv-subscription p:last-child {
    margin-bottom: 0;
  }

  .cbv-caption {
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 16px;
    display: block;
    color: var(--color-accent);
  }

  /* Buttons */
  .cbv-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 40px;
    background-color: var(--color-text);
    color: var(--color-bg);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 13px;
    font-weight: 500;
    transition: background-color 0.3s ease, transform 0.3s ease, color 0.3s ease;
    border: 1px solid var(--color-text);
    cursor: pointer;
  }
  .cbv-btn:hover {
    background-color: transparent;
    color: var(--color-text);
  }
  .cbv-btn-secondary {
    background-color: transparent;
    color: var(--color-text);
  }
  .cbv-btn-secondary:hover {
    background-color: var(--color-text);
    color: var(--color-bg);
  }

  /* SVG Placeholders */
  .cbv-placeholder {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    background-color: rgba(0,0,0,0.03);
  }

  /* ------------------------------ */
  /* BLOCK STYLES                   */
  /* ------------------------------ */

  /* Split Hero with Typo Art */
  .cbv-split-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 80vh;
  }
  .cbv-split-hero__art {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(32px, 5vw, 64px) clamp(16px, 5vw, 32px);
    width: 100%;
    height: 100%;
    position: relative;
  }
  
  /* The Typographic Logo Plaque (Fluid) */
  .cbv-typo-plaque {
    position: relative;
    width: 100%;
    max-width: 420px;
    aspect-ratio: 4 / 5;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: clamp(6px, 2vw, 12px);
    margin: 0 auto;
  }
  .cbv-typo-plaque__inner {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: clamp(16px, 6vw, 40px);
  }
  .cbv-typo-plaque__top {
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: clamp(9px, 2vw, 11px);
    display: block;
    margin-bottom: clamp(16px, 4vw, 24px);
  }
  .cbv-typo-plaque__main {
    font-family: var(--font-heading);
    font-size: clamp(36px, 8vw, 64px);
    line-height: 1.05;
    display: block;
    font-style: italic;
    margin-bottom: clamp(24px, 5vw, 32px);
    word-break: normal;
    overflow-wrap: normal;
  }
  .cbv-typo-plaque__bottom {
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: clamp(8px, 1.5vw, 10px);
    display: inline-block;
    padding-top: clamp(16px, 4vw, 24px);
    border-top: 1px solid currentColor;
  }

  .cbv-split-hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(64px, 8vw, 96px) clamp(24px, 8vw, 8vw);
  }
  .cbv-split-hero h1 {
    font-size: clamp(40px, 5vw, 64px);
    margin-bottom: 24px;
  }
  .cbv-split-hero .cbv-btn {
    margin-top: 24px;
    align-self: flex-start;
  }

  /* Benefits */
  .cbv-benefits {
    padding: clamp(80px, 8vw, 128px) 32px;
    max-width: 1400px;
    margin: 0 auto;
  }
  .cbv-benefits__header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto clamp(48px, 6vw, 80px);
  }
  .cbv-benefits__header h2 {
    font-size: clamp(36px, 4vw, 56px);
  }
  .cbv-benefits__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(48px, 6vw, 80px) 48px;
  }
  .cbv-benefit {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-left: clamp(20px, 3vw, 32px);
    border-left: 1px solid var(--color-accent);
  }
  .cbv-benefit h3 {
    font-size: clamp(24px, 2.5vw, 32px);
    margin-bottom: 16px;
  }

  /* Steps */
  .cbv-steps {
    padding: clamp(80px, 8vw, 128px) 32px;
    background-color: rgba(0,0,0,0.02);
  }
  .cbv-steps__header {
    text-align: center;
    margin-bottom: clamp(64px, 8vw, 96px);
  }
  .cbv-steps__header h2 {
    font-size: clamp(32px, 4vw, 48px);
  }
  .cbv-steps__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(48px, 6vw, 64px);
    max-width: 1400px;
    margin: 0 auto;
  }
  .cbv-step {
    position: relative;
    text-align: center;
  }
  .cbv-step__num {
    font-family: var(--font-heading);
    font-size: clamp(56px, 8vw, 96px);
    color: var(--color-accent);
    opacity: 0.2;
    line-height: 1;
    margin-bottom: 24px;
    display: block;
    font-style: italic;
  }
  .cbv-step h3 {
    font-size: clamp(22px, 2vw, 28px);
  }

  /* Flexibility Banner */
  .cbv-flex-banner {
    position: relative;
    padding: clamp(96px, 10vw, 160px) 32px;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cbv-flex-banner__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }
  .cbv-flex-banner__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
  }
  .cbv-flex-banner__content {
    position: relative;
    z-index: 3;
    max-width: 800px;
  }
  .cbv-flex-banner h2 {
    font-size: clamp(36px, 5vw, 64px);
    margin-bottom: 24px;
  }

  /* CTA Block */
  .cbv-cta-block {
    padding: clamp(80px, 8vw, 128px) 32px;
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }
  .cbv-cta-block h2 {
    font-size: clamp(36px, 4vw, 56px);
    margin-bottom: 40px;
  }
  .cbv-cta-block__buttons {
    display: flex;
    gap: 24px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Responsive Adjustments */
  @media screen and (max-width: 1000px) {
    .cbv-split-hero {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .cbv-split-hero__art {
      min-height: 50vh;
    }
    .cbv-benefits__grid {
      grid-template-columns: 1fr;
    }
    .cbv-steps__grid {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 600px) {
    .cbv-benefits, .cbv-steps, .cbv-flex-banner, .cbv-cta-block {
      padding-left: 24px;
      padding-right: 24px;
    }
    .cbv-cta-block__buttons {
      flex-direction: column;
      width: 100%;
    }
    .cbv-cta-block__buttons .cbv-btn {
      width: 100%;
    }
  }
</style>

<div class="cbv-subscription">
  {% for block in section.blocks %}
    {% case block.type %}
      
      {% when 'split_hero' %}
        <section class="cbv-split-hero" {{ block.shopify_attributes }}>
          
          <!-- Typographic Art Block -->
          <div class="cbv-split-hero__art" style="background: {{ block.settings.art_gradient }};">
            <div class="cbv-typo-plaque reveal-up" style="color: {{ block.settings.art_text_color }}; border: 1px solid {{ block.settings.art_border_color }};">
              <div class="cbv-typo-plaque__inner" style="border: 1px solid {{ block.settings.art_border_color }};">
                {% if block.settings.logo_top != blank %}
                  <span class="cbv-typo-plaque__top">{{ block.settings.logo_top }}</span>
                {% endif %}
                {% if block.settings.logo_main != blank %}
                  <span class="cbv-typo-plaque__main">{{ block.settings.logo_main }}</span>
                {% endif %}
                {% if block.settings.logo_bottom != blank %}
                  <span class="cbv-typo-plaque__bottom">{{ block.settings.logo_bottom }}</span>
                {% endif %}
              </div>
            </div>
          </div>

          <!-- Hero Text Content -->
          <div class="cbv-split-hero__content reveal-up" style="background-color: {{ block.settings.bg_color }};">
            {% if block.settings.caption != blank %}
              <span class="cbv-caption">{{ block.settings.caption }}</span>
            {% endif %}
            {% if block.settings.heading != blank %}
              <h1>{{ block.settings.heading }}</h1>
            {% endif %}
            {% if block.settings.text != blank %}
              <div>{{ block.settings.text }}</div>
            {% endif %}
            {% if block.settings.button_label != blank %}
              <a href="{{ block.settings.button_link }}" class="cbv-btn">{{ block.settings.button_label }}</a>
            {% endif %}
          </div>
        </section>

      {% when 'benefits' %}
        <section class="cbv-benefits" {{ block.shopify_attributes }}>
          <div class="cbv-benefits__header reveal-up">
            {% if block.settings.caption != blank %}
              <span class="cbv-caption">{{ block.settings.caption }}</span>
            {% endif %}
            {% if block.settings.title != blank %}
              <h2>{{ block.settings.title }}</h2>
            {% endif %}
          </div>
          <div class="cbv-benefits__grid">
            {% for i in (1..4) %}
              {% capture title_key %}title_{{ i }}{% endcapture %}
              {% capture text_key %}text_{{ i }}{% endcapture %}
              {% assign p_title = block.settings[title_key] %}
              {% assign p_text = block.settings[text_key] %}
              
              {% if p_title != blank %}
                <div class="cbv-benefit reveal-up" style="transition-delay: {{ i | times: 0.1 }}s;">
                  <h3>{{ p_title }}</h3>
                  <div>{{ p_text }}</div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </section>

      {% when 'steps' %}
        <section class="cbv-steps" {{ block.shopify_attributes }}>
          <div class="cbv-steps__header reveal-up">
            {% if block.settings.caption != blank %}
              <span class="cbv-caption">{{ block.settings.caption }}</span>
            {% endif %}
            {% if block.settings.title != blank %}
              <h2>{{ block.settings.title }}</h2>
            {% endif %}
          </div>
          <div class="cbv-steps__grid">
            {% for i in (1..3) %}
              {% capture title_key %}title_{{ i }}{% endcapture %}
              {% capture text_key %}text_{{ i }}{% endcapture %}
              {% assign s_title = block.settings[title_key] %}
              {% assign s_text = block.settings[text_key] %}
              
              {% if s_title != blank %}
                <div class="cbv-step reveal-up" style="transition-delay: {{ i | times: 0.1 }}s;">
                  <span class="cbv-step__num">0{{ i }}</span>
                  <h3>{{ s_title }}</h3>
                  <div>{{ s_text }}</div>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </section>

      {% when 'flexibility_banner' %}
        <section class="cbv-flex-banner" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | img_url: '2000x' }}" class="cbv-flex-banner__bg" alt="" loading="lazy">
          {% else %}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'cbv-placeholder cbv-flex-banner__bg' }}
          {% endif %}
          
          <div class="cbv-flex-banner__overlay" style="background-color: {{ block.settings.bg_color }}; opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"></div>
          
          <div class="cbv-flex-banner__content reveal-up">
            {% if block.settings.heading != blank %}
              <h2 style="color: {{ block.settings.text_color }}">{{ block.settings.heading }}</h2>
            {% endif %}
            {% if block.settings.text != blank %}
              <div style="color: {{ block.settings.text_color }}">{{ block.settings.text }}</div>
            {% endif %}
          </div>
        </section>

      {% when 'cta' %}
        <section class="cbv-cta-block reveal-up" {{ block.shopify_attributes }}>
          {% if block.settings.caption != blank %}
            <span class="cbv-caption">{{ block.settings.caption }}</span>
          {% endif %}
          {% if block.settings.heading != blank %}
            <h2>{{ block.settings.heading }}</h2>
          {% endif %}
          <div class="cbv-cta-block__buttons">
            {% if block.settings.button_1_label != blank %}
              <a href="{{ block.settings.button_1_link }}" class="cbv-btn">{{ block.settings.button_1_label }}</a>
            {% endif %}
            {% if block.settings.button_2_label != blank %}
              <a href="{{ block.settings.button_2_link }}" class="cbv-btn cbv-btn-secondary">{{ block.settings.button_2_label }}</a>
            {% endif %}
          </div>
        </section>

    {% endcase %}
  {% endfor %}
</div>

<script>
  function initSubscriptionAnimations() {
    if (window.Shopify && window.Shopify.designMode) {
      document.querySelectorAll('.reveal-up').forEach(el => {
        el.classList.add('is-visible');
        el.style.opacity = '1';
        el.style.transform = 'none';
        el.style.transition = 'none';
      });
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.15,
      rootMargin: "0px 0px -50px 0px"
    });

    document.querySelectorAll('.reveal-up:not(.is-visible)').forEach(el => observer.observe(el));
  }

  document.addEventListener('DOMContentLoaded', initSubscriptionAnimations);
  document.addEventListener('shopify:section:load', initSubscriptionAnimations);
</script>

{% schema %}
{
  "name": "Subscription Editorial",
  "settings":[
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#FAF9F6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#2C2C2C"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#A68A6D"
    }
  ],
  "blocks":[
    {
      "type": "split_hero",
      "name": "Typographic Split Hero",
      "settings":[
        { "type": "header", "content": "Typographic Logo Art" },
        { "type": "color_background", "id": "art_gradient", "label": "Art Background Gradient", "default": "linear-gradient(135deg, #F4F0EB 0%, #E3D7C8 100%)" },
        { "type": "color", "id": "art_text_color", "label": "Logo Text Color", "default": "#2C2C2C" },
        { "type": "color", "id": "art_border_color", "label": "Logo Border Color", "default": "#A68A6D" },
        { "type": "text", "id": "logo_top", "label": "Logo Top Text", "default": "The Signature" },
        { "type": "text", "id": "logo_main", "label": "Logo Main Text", "default": "Candle<br>Club", "info": "Use <br> to force a line break." },
        { "type": "text", "id": "logo_bottom", "label": "Logo Bottom Text", "default": "Premium Subscription" },
        
        { "type": "header", "content": "Hero Text Content" },
        { "type": "color", "id": "bg_color", "label": "Text Side Background", "default": "#FAF9F6" },
        { "type": "text", "id": "caption", "label": "Caption", "default": "Elevate Your Routine" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Your signature scents, always in stock." },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Save on every order, discover new scents, and enjoy premium handcrafted candles delivered on your exact schedule.</p>" },
        { "type": "text", "id": "button_label", "label": "Button Label", "default": "Shop Subscriptions" },
        { "type": "url", "id": "button_link", "label": "Button Link" }
      ]
    },
    {
      "type": "benefits",
      "name": "Club Benefits Grid",
      "settings":[
        { "type": "text", "id": "caption", "label": "Caption", "default": "Why Join" },
        { "type": "text", "id": "title", "label": "Heading", "default": "The perks of the Candle Club." },
        { "type": "text", "id": "title_1", "label": "Benefit 1 Title", "default": "Subscribe & Save" },
        { "type": "richtext", "id": "text_1", "label": "Benefit 1 Text", "default": "<p>Enjoy preferred pricing on recurring deliveries of your signature scents.</p>" },
        { "type": "text", "id": "title_2", "label": "Benefit 2 Title", "default": "Never Run Out" },
        { "type": "richtext", "id": "text_2", "label": "Benefit 2 Text", "default": "<p>Keep your home beautifully stocked with everyday staples and seasonal picks.</p>" },
        { "type": "text", "id": "title_3", "label": "Benefit 3 Title", "default": "Flexible Delivery" },
        { "type": "richtext", "id": "text_3", "label": "Benefit 3 Text", "default": "<p>Choose a cadence that fits your routine. Designed for real life, not rigid plans.</p>" },
        { "type": "text", "id": "title_4", "label": "Benefit 4 Title", "default": "Endless Discovery" },
        { "type": "richtext", "id": "text_4", "label": "Benefit 4 Text", "default": "<p>Explore CBV's massive fragrance library and uncover new favorites over time.</p>" }
      ]
    },
    {
      "type": "steps",
      "name": "How It Works",
      "settings":[
        { "type": "text", "id": "caption", "label": "Caption", "default": "How It Works" },
        { "type": "text", "id": "title", "label": "Heading", "default": "A simple, seamless experience." },
        { "type": "text", "id": "title_1", "label": "Step 1 Title", "default": "Curate Your Box" },
        { "type": "richtext", "id": "text_1", "label": "Step 1 Text", "default": "<p>Select custom candles, standard pours, or wax melts from the collections you love.</p>" },
        { "type": "text", "id": "title_2", "label": "Step 2 Title", "default": "Set Your Rhythm" },
        { "type": "richtext", "id": "text_2", "label": "Step 2 Text", "default": "<p>Pick a delivery interval that works perfectly for your home and burning habits.</p>" },
        { "type": "text", "id": "title_3", "label": "Step 3 Title", "default": "Unbox the Magic" },
