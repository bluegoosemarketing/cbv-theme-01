      ]
    },
    {
      "type": "flexibility_banner",
      "name": "Flexibility Banner",
      "settings":[
        { "type": "image_picker", "id": "image", "label": "Background Image" },
        { "type": "color", "id": "bg_color", "label": "Background Color Overlay", "default": "#1a1a1a" },
        { "type": "range", "id": "overlay_opacity", "min": 0, "max": 100, "step": 5, "label": "Overlay Opacity", "default": 80 },
        { "type": "color", "id": "text_color", "label": "Text Color", "default": "#FAF9F6" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Total Control. Zero Friction." },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Built for absolute flexibility — pause, skip, adjust your scents, or cancel your shipments at any time directly from your account portal.</p>" }
      ]
    },
    {
      "type": "cta",
      "name": "Dual Call to Action",
      "settings":[
        { "type": "text", "id": "caption", "label": "Caption", "default": "Start Your Subscription" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Bring premium fragrance home, on repeat." },
        { "type": "text", "id": "button_1_label", "label": "Button 1 Label", "default": "Explore Candles" },
        { "type": "url", "id": "button_1_link", "label": "Button 1 Link" },
        { "type": "text", "id": "button_2_label", "label": "Button 2 Label", "default": "Shop Wax Melts" },
        { "type": "url", "id": "button_2_link", "label": "Button 2 Link" }
      ]
    }
  ],
  "presets":[
    {
      "name": "Subscription Editorial"
    }
  ]
}
{% endschema %}
