{{ 'section-cbv-collection-size-selector.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 990px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign default_index = 0
  assign desired_default = section.settings.default_size_label | strip | downcase

  if section.blocks.size > 0 and desired_default != blank
    for block in section.blocks
      assign block_label = block.settings.size_label | strip | downcase
      if block_label == desired_default
        assign default_index = forloop.index0
        break
      endif
    endfor
  endif

  assign default_block = section.blocks[default_index]
  assign default_title = default_block.settings.title | default: default_block.settings.size_label
-%}

<section class="cbv-size-selector section-{{ section.id }}-padding" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- if section.blocks.size > 0 -%}
      <div class="cbv-size-selector__layout">
        
        <!-- LEFT: EDITORIAL VISUAL PANEL -->
        <div class="cbv-size-selector__media-col">
          <div class="cbv-size-selector__media-wrapper">
            <div class="cbv-media-badge">Step 1: Size</div>
            {%- if default_block.settings.image != blank -%}
              {{
                default_block.settings.image
                | image_url: width: 1400
                | image_tag:
                  loading: 'eager',
                  widths: '400, 600, 800, 1000, 1200',
                  class: 'cbv-size-image',
                  alt: default_title
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'cbv-size-image cbv-placeholder' }}
            {%- endif -%}
          </div>
        </div>

        <!-- RIGHT: FOCUSED ACTION PANEL -->
        <div class="cbv-size-selector__content-col">
          
          <div class="cbv-content-header">
            <p class="cbv-eyebrow">{{ section.settings.eyebrow | escape | default: 'Custom Candle Builder' }}</p>
            <h1 class="cbv-title" data-size-title>{{ default_title | escape }}</h1>
          </div>

          <!-- CORE ACTION PULLED TO THE TOP -->
          <div class="cbv-selection-area">
            <div class="cbv-selection-header">
              <span class="cbv-label">Select Candle Size</span>
            </div>
            <div class="cbv-size-grid">
              {%- for block in section.blocks -%}
                {%- assign button_label = block.settings.size_label | default: block.settings.title -%}
                <button
                  type="button"
                  class="cbv-size-btn{% if forloop.index0 == default_index %} is-active{% endif %}"
                  data-size-button
                  data-size-index="{{ forloop.index0 }}"
                  aria-pressed="{% if forloop.index0 == default_index %}true{% else %}false{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {{ button_label | escape }}
                </button>
              {%- endfor -%}
            </div>
          </div>

          <!-- CONSOLIDATED INFO CARD -->
          <div class="cbv-info-card">
            <div class="cbv-info-card__header">
              <div class="cbv-badge" data-size-room-badge {% if default_block.settings.room_recommendation == blank %}style="display:none;"{% endif %}>
                Ideal for: <span data-size-room>{{ default_block.settings.room_recommendation | escape }}</span>
              </div>
              <p class="cbv-description" data-size-description>{{ default_block.settings.description | escape }}</p>
            </div>

            <div class="cbv-info-card__divider"></div>

            <div class="cbv-specs-row">
              <div class="cbv-spec-item">
                <div class="cbv-spec-text">
                  <span class="cbv-spec-label">Wick Count</span>
                  <strong data-size-wicks>{{ default_block.settings.wick_count | escape }}</strong>
                </div>
              </div>
              <div class="cbv-spec-item">
                <div class="cbv-spec-text">
                  <span class="cbv-spec-label">Wood Wick Option</span>
                  <strong data-size-wood>{{ default_block.settings.wood_wick | escape }}</strong>
                </div>
              </div>
            </div>

            <div class="cbv-styles-preview">
              <div class="cbv-styles-header">
                <span class="cbv-spec-label">Jar Styles Available</span>
                <span class="cbv-styles-note">{{ section.settings.styles_note | escape }}</span>
              </div>
              <div class="cbv-styles-list" data-size-styles>
                <!-- JS Populated -->
              </div>
            </div>
          </div>

          <!-- PRIMARY CTA -->
          <a
            class="cbv-grand-cta{% if default_block.settings.builder_link == blank %} is-disabled{% endif %}"
            data-size-cta
            href="{% if default_block.settings.builder_link != blank %}{{ default_block.settings.builder_link }}{% else %}#{% endif %}"
          >
            <span>{{ section.settings.cta_label | escape | default: 'Next Step: Customize' }}</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>
        </div>
      </div>

      <!-- JS DATA -->
      <script type="application/json" data-size-data>[
          {%- for block in section.blocks -%}
            {
              "label": {{ block.settings.size_label | default: block.settings.title | json }},
              "title": {{ block.settings.title | default: block.settings.size_label | json }},
              "room": {{ block.settings.room_recommendation | json }},
              "description": {{ block.settings.description | json }},
              "wicks": {{ block.settings.wick_count | json }},
              "woodWick": {{ block.settings.wood_wick | json }},
              "styles": {{ block.settings.jar_styles | json }},
              "builderLink": {{ block.settings.builder_link | json }},
              "image": {%- if block.settings.image != blank -%}
                {
                  "src": {{ block.settings.image | image_url: width: 1400 | json }},
                  "alt": {{ block.settings.title | default: block.settings.size_label | json }}
                }
              {%- else -%}
                null
              {%- endif -%}
            }{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        ]
      </script>

      <script>
        document.addEventListener('DOMContentLoaded', () => {
          const sectionEl = document.querySelector('[data-section-id="{{ section.id }}"]');
          if (!sectionEl) return;

          const dataScript = sectionEl.querySelector('[data-size-data]');
          if (!dataScript) return;

          let options;
          try { options = JSON.parse(dataScript.textContent); } catch (e) { return; }
          if (!Array.isArray(options) || !options.length) return;

          const imageEl = sectionEl.querySelector('.cbv-size-image');
          const titleEl = sectionEl.querySelector('[data-size-title]');
          const roomBadgeEl = sectionEl.querySelector('[data-size-room-badge]');
          const roomEl = sectionEl.querySelector('[data-size-room]');
          const descriptionEl = sectionEl.querySelector('[data-size-description]');
          const stylesListEl = sectionEl.querySelector('[data-size-styles]');
          const wicksEl = sectionEl.querySelector('[data-size-wicks]');
          const woodEl = sectionEl.querySelector('[data-size-wood]');
          const ctaEl = sectionEl.querySelector('[data-size-cta]');
          const buttons = sectionEl.querySelectorAll('[data-size-button]');
          const scentParam = new URLSearchParams(window.location.search).get('scent');

          const appendScentParam = (url) => {
            if (!url || !scentParam) return url;
            const [base, hash = ''] = url.split('#');
            const joiner = base.includes('?') ? '&' : '?';
            const nextUrl = `${base}${joiner}scent=${encodeURIComponent(scentParam)}`;
            return hash ? `${nextUrl}#${hash}` : nextUrl;
          };

          const parseStyles = (styles) => {
            if (!styles) return[];
            return styles.split(/[\n,]/).map(s => s.trim()).filter(Boolean);
          };

          const renderStyles = (styles) => {
            if (!stylesListEl) return;
            stylesListEl.innerHTML = '';
            const entries = parseStyles(styles);
            if (!entries.length) {
              const empty = document.createElement('span');
              empty.className = 'cbv-style-pill is-empty';
              empty.textContent = 'None listed';
              stylesListEl.appendChild(empty);
              return;
            }
            entries.forEach(style => {
              const tag = document.createElement('span');
              tag.className = 'cbv-style-pill';
              tag.textContent = style;
              stylesListEl.appendChild(tag);
            });
          };

          const updateImage = (image) => {
            if (!imageEl) return;
            imageEl.classList.add('is-changing');
            
            setTimeout(() => {
                if (image && image.src) {
                    imageEl.src = image.src;
                    imageEl.alt = image.alt || '';
                }
                imageEl.onload = () => imageEl.classList.remove('is-changing');
                setTimeout(() => imageEl.classList.remove('is-changing'), 200);
            }, 150);
          };

          const select = (index) => {
            const selected = options[index];
            if (!selected) return;

            buttons.forEach((btn, idx) => {
              const active = idx === index;
              btn.classList.toggle('is-active', active);
              btn.setAttribute('aria-pressed', active);
            });

            if (titleEl) titleEl.textContent = selected.title;
            if (descriptionEl) descriptionEl.textContent = selected.description;
            if (wicksEl) wicksEl.textContent = selected.wicks;
            if (woodEl) woodEl.textContent = selected.woodWick;

            if (roomBadgeEl) {
                if (selected.room) {
                    roomBadgeEl.style.display = 'inline-flex';
                    if (roomEl) roomEl.textContent = selected.room;
                } else {
                    roomBadgeEl.style.display = 'none';
                }
            }

            renderStyles(selected.styles);

            if (ctaEl) {
                if (selected.builderLink) {
                    ctaEl.href = appendScentParam(selected.builderLink);
                    ctaEl.classList.remove('is-disabled');
                } else {
                    ctaEl.href = '#';
                    ctaEl.classList.add('is-disabled');
                }
            }

            updateImage(selected.image);
          };

          buttons.forEach(btn => {
            btn.addEventListener('click', () => select(Number(btn.dataset.sizeIndex)));
          });

          select({{ default_index }});
        });
      </script>
    {%- else -%}
      <div class="cbv-size-empty">Please add size blocks in the theme editor.</div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "CBV Size Selector",
  "tag": "section",
  "class": "section",
  "settings":[
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Step 1: Choose Your Size"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Button Label",
      "default": "Next Step: Customize"
    },
    {
      "type": "text",
      "id": "styles_note",
      "label": "Styles Note",
      "default": "(Selection happens in the next step)"
    },
    {
      "type": "text",
      "id": "default_size_label",
      "label": "Default Active Size",
      "info": "Must match a block label exactly (e.g. '12oz')",
      "default": "12oz"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    }
  ],
  "blocks":[
    {
      "type": "size_option",
      "name": "Size Option",
      "settings":[
        {
          "type": "text",
          "id": "size_label",
          "label": "Button Label",
          "default": "12oz"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Display Title",
          "default": "12oz Candle"
        },
        {
          "type": "text",
          "id": "room_recommendation",
          "label": "Room Recommendation",
          "placeholder": "Bedrooms & Kitchens"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Our most beloved size. Perfectly balanced proportions for living rooms."
        },
        {
          "type": "text",
          "id": "wick_count",
          "label": "Wick Count",
          "default": "1"
        },
        {
          "type": "text",
          "id": "wood_wick",
          "label": "Wood Wick Option",
          "default": "Yes"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Preview Image"
        },
        {
          "type": "textarea",
          "id": "jar_styles",
          "label": "Jar Styles List",
          "info": "Enter one style per line or comma separated",
          "default": "Clear Glass\nSeafoam\nBlush\nIridescent"
        },
        {
          "type": "url",
          "id": "builder_link",
          "label": "Link to Product"
        }
      ]
    }
  ],
  "presets":[
    {
      "name": "CBV Size Selector",
      "blocks":[
        { "type": "size_option", "settings": { "size_label": "4oz", "title": "4oz Candle" } },
        { "type": "size_option", "settings": { "size_label": "9oz", "title": "9oz Candle" } },
        { "type": "size_option", "settings": { "size_label": "12oz", "title": "12oz Candle" } },
        { "type": "size_option", "settings": { "size_label": "16oz", "title": "16oz Candle" } }
      ]
    }
  ]
}
{% endschema %}