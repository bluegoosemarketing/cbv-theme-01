  #shopify-section-header, 
  .shopify-section-header, 
  .section-header {
    position: relative !important;
    z-index: 99999 !important;
  }

  .cbv-lib-controls {
    z-index: 10 !important; 
  }

  /* --- MINIMAL BUILDER HEADER (The "Checkout Flow" Focus) --- */
  .cbv-header-fixed-group--minimal {
    background: #fdfbf7;
  }

  .cbv-header-fixed-group--minimal .cbv-header {
    padding: 0 40px;
  }

  .cbv-header-fixed-group--minimal .cbv-header-top {
    padding: 8px 0;
    min-height: 64px;
  }

  .cbv-header-fixed-group--minimal .cbv-builder-exit {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #888;
    text-decoration: none;
    font-size: 12px;
    font-family: "Avenir Next", "Helvetica Neue", sans-serif;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .cbv-header-fixed-group--minimal .cbv-builder-exit:hover {
    color: #111;
    transform: translateX(-3px);
  }

  .cbv-header-fixed-group--minimal .cbv-icons {
    gap: 0;
  }

  .cbv-header-fixed-group--minimal.is-scrolled .cbv-header-top {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: auto;
    padding: 8px 0;
    pointer-events: auto;
  }

  .cbv-header-fixed-group--minimal.is-scrolled .cbv-logo-center {
    opacity: 1;
    transform: none;
    pointer-events: auto;
    height: auto;
    overflow: visible;
  }

  .cbv-header-fixed-group--minimal.is-scrolled .cbv-logo-sticky {
    opacity: 0;
    width: 0;
    overflow: hidden;
  }

  .cbv-header-fixed-group--minimal.is-scrolled .cbv-header-left,
  .cbv-header-fixed-group--minimal.is-scrolled .cbv-icons {
    pointer-events: auto;
  }

  @media (max-width: 1024px) {
    .cbv-header-fixed-group--minimal .cbv-header {
      padding: 0 20px;
      height: 64px;
      border-bottom: 1px solid var(--cbv-border-color);
    }

    .cbv-header-fixed-group--minimal .cbv-mobile-header {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      column-gap: 8px;
    }

    .cbv-header-fixed-group--minimal .cbv-mobile-logo {
      flex: initial;
      min-width: 0;
    }

    .cbv-header-fixed-group--minimal .cbv-mobile-logo .cbv-builder-progress {
      display: block; /* Show pill on mobile minimal */
      margin-top: 4px;
      font-size: 8px;
      letter-spacing: 1px;
      padding: 3px 8px;
    }

    .cbv-header-fixed-group--minimal .cbv-mobile-icons {
      justify-content: flex-end;
    }

    .cbv-header-fixed-group--minimal .cbv-builder-exit {
      font-size: 11px;
      letter-spacing: 0.5px;
      white-space: nowrap;
    }
    
    .cbv-header-fixed-group--minimal .cbv-builder-exit span { display: none; } /* Hide text, just show arrow on mobile */
  }
{% endstyle %}

