{% javascript %}
  (() => {
    const init = () => {
      // 1. Mobile Drawer
      const body = document.body;
      const drawer = document.querySelector('[data-cbv-mobile-drawer]');
      const overlay = document.querySelector('[data-cbv-mobile-overlay]');
      const toggles = document.querySelectorAll('[data-cbv-toggle-drawer]');
      const accordionButtons = document.querySelectorAll('[data-cbv-accordion]');

      if (drawer && overlay) {
        const toggleDrawer = () => {
          const open = drawer.classList.toggle('is-open');
          overlay.classList.toggle('is-active', open);
          body.style.overflow = open ? 'hidden' : '';
        };

        toggles.forEach((button) => {
          button.addEventListener('click', toggleDrawer);
        });

        overlay.addEventListener('click', toggleDrawer);

        accordionButtons.forEach((button) => {
          button.addEventListener('click', () => {
            button.parentElement.classList.toggle('is-expanded');
          });
        });
      }

      // 2. Fixed Header Morph & dynamic page padding Logic
      const fixedGroup = document.querySelector('.cbv-header-fixed-group');
      if (!fixedGroup) return;

      // Replaces manual offset setup with robust ResizeObserver 
      // This protects against custom fonts/images dynamically expanding the header.
      const headerObserver = new ResizeObserver((entries) => {
        for (let entry of entries) {
          if (!fixedGroup.classList.contains('is-scrolled')) {
            document.documentElement.style.setProperty('--cbv-header-offset', `${entry.target.offsetHeight}px`);
          }
        }
      });
      headerObserver.observe(fixedGroup);

      // Scroll Handler
      let ticking = false;
      const SCROLL_THRESHOLD = 50;

      const onScroll = () => {
        const currentScroll = window.scrollY;
        
        if (currentScroll > SCROLL_THRESHOLD) {
          fixedGroup.classList.add('is-scrolled');
        } else {
          fixedGroup.classList.remove('is-scrolled');
        }
      };

      window.addEventListener('scroll', () => {
        if (!ticking) {
          window.requestAnimationFrame(() => {
            onScroll();
            ticking = false;
          });
          ticking = true;
        }
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
      init();
    }
  })();
{% endjavascript %}