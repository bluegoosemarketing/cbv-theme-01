{% comment %}
  Section: FAQ Editorial
  Description: A premium, single-column FAQ section with inline category subheadings.
{% endcomment %}

<style>
  /* CSS Reset & Scope Firewall */
  .cbv-faq {
    --color-bg: {{ section.settings.bg_color }};
    --color-text: {{ section.settings.text_color }};
    --color-accent: {{ section.settings.accent_color }};
    --font-heading: var(--font-heading-family, "Playfair Display", Georgia, serif);
    --font-body: var(--font-body-family, "Helvetica Neue", Arial, sans-serif);
    
    background-color: var(--color-bg);
    color: var(--color-text);
    overflow: hidden;
    position: relative;
    font-size: 16px; 
    box-sizing: border-box;
  }

  .cbv-faq * {
    box-sizing: border-box;
  }

  /* Reveal Animations */
  .reveal-up {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .reveal-up.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Typography */
  .cbv-faq h1, .cbv-faq h2, .cbv-faq h3 {
    font-family: var(--font-heading);
    font-weight: 400;
    line-height: 1.15;
    color: currentColor;
    margin: 0 0 24px 0;
  }
  
  .cbv-faq p {
    font-family: var(--font-body);
    line-height: 1.7;
    margin: 0 0 24px 0;
    font-size: clamp(15px, 1.2vw, 17px); 
    letter-spacing: 0.3px;
  }
  .cbv-faq p:last-child { margin-bottom: 0; }

  .cbv-caption {
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 16px;
    display: block;
    color: var(--color-accent);
  }

  /* Button */
  .cbv-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 40px;
    background-color: var(--color-text);
    color: var(--color-bg);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 13px;
    font-weight: 500;
    transition: background-color 0.3s ease, color 0.3s ease;
    border: 1px solid var(--color-text);
    cursor: pointer;
  }
  .cbv-btn:hover {
    background-color: transparent;
    color: var(--color-text);
  }

  /* Hero Section */
  .cbv-faq__hero {
    text-align: center;
    padding: clamp(96px, 10vw, 128px) 32px;
    background: {{ section.settings.hero_gradient }};
  }
  .cbv-faq__hero-inner {
    max-width: 800px;
    margin: 0 auto;
  }
  .cbv-faq__hero h1 {
    font-size: clamp(40px, 5vw, 64px);
    margin-bottom: 24px;
  }

  /* FAQ Container (Single Column) */
  .cbv-faq__wrapper {
    max-width: 840px; /* Optimal reading width */
    margin: 0 auto;
    padding: clamp(64px, 8vw, 128px) 32px;
  }

  /* Inline Category Heading - FIXED SPECIFICITY & STYLING */
  .cbv-faq h2.cbv-faq__category-title {
    font-family: var(--font-heading);
    font-size: clamp(24px, 4vw, 32px);
    color: var(--color-text);
    margin: 80px 0 24px 0; /* Forced margin via h2 tag specification */
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-accent);
  }
  .cbv-faq h2.cbv-faq__category-title:first-child {
    margin-top: 0;
  }

  /* Accordion Layout */
  .cbv-faq__item {
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }
  .cbv-faq__question {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: clamp(16px, 1.5vw, 20px);
    font-weight: 500;
    color: var(--color-text);
    text-align: left;
    line-height: 1.4;
  }
  
  /* Plus / Minus Icon - Thinned out for elegance */
  .cbv-faq__icon {
    position: relative;
    width: 12px;
    height: 12px;
    flex-shrink: 0;
    margin-left: 24px;
  }
  .cbv-faq__icon::before,
  .cbv-faq__icon::after {
    content: '';
    position: absolute;
    background-color: var(--color-accent);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.4s ease;
  }
  .cbv-faq__icon::before { width: 100%; height: 1px; }
  .cbv-faq__icon::after { height: 100%; width: 1px; }
  
  .cbv-faq__item.is-active .cbv-faq__icon::after {
    transform: translate(-50%, -50%) rotate(90deg);
    opacity: 0;
  }

  /* Answer Content */
  .cbv-faq__answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .cbv-faq__answer-inner {
    padding-bottom: 32px;
    padding-right: 24px;
    color: rgba(0,0,0,0.75);
  }

  /* Footer CTA */
  .cbv-faq__cta {
    text-align: center;
    padding: clamp(80px, 8vw, 128px) 32px;
    background-color: rgba(0,0,0,0.02);
  }
  .cbv-faq__cta h2 {
    font-size: clamp(32px, 4vw, 48px);
    margin-bottom: 32px;
  }

  /* Responsive Adjustments */
  @media screen and (max-width: 600px) {
    .cbv-faq__hero, .cbv-faq__wrapper, .cbv-faq__cta {
      padding-left: 24px;
      padding-right: 24px;
    }
    .cbv-faq h2.cbv-faq__category-title {
      margin: 56px 0 16px 0; /* Proper spacing restored */
      font-size: 24px;
    }
    .cbv-faq__question {
      font-size: 16px;
      padding: 20px 0;
    }
    .cbv-faq__answer-inner {
      padding-right: 0;
    }
  }
</style>

<div class="cbv-faq">
  
  <!-- Section Hero -->
  <section class="cbv-faq__hero">
    <div class="cbv-faq__hero-inner reveal-up">
      {% if section.settings.caption != blank %}
        <span class="cbv-caption">{{ section.settings.caption }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h1>{{ section.settings.heading }}</h1>
      {% endif %}
      {% if section.settings.text != blank %}
        <div>{{ section.settings.text }}</div>
      {% endif %}
    </div>
  </section>

  <!-- FAQ List (Unified Single Column) -->
  <section class="cbv-faq__wrapper">
    {% for block in section.blocks %}
      
      {% if block.type == 'category' %}
        <h2 class="cbv-faq__category-title reveal-up" {{ block.shopify_attributes }}>
          {{ block.settings.title }}
        </h2>
        
      {% elsif block.type == 'question' %}
        <div class="cbv-faq__item reveal-up" {{ block.shopify_attributes }}>
          <button class="cbv-faq__question" aria-expanded="false">
            {{ block.settings.title }}
            <span class="cbv-faq__icon"></span>
          </button>
          <div class="cbv-faq__answer">
            <div class="cbv-faq__answer-inner">
              {{ block.settings.answer }}
            </div>
          </div>
        </div>
      {% endif %}
      
    {% endfor %}
  </section>

  <!-- CTA Footer -->
  <section class="cbv-faq__cta reveal-up">
    <h2>{{ section.settings.cta_heading }}</h2>
    <a href="{{ section.settings.cta_button_link }}" class="cbv-btn">{{ section.settings.cta_button_label }}</a>
  </section>

</div>

<script>
  function initFAQ() {
    // Reveal Animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: "0px 0px -50px 0px"
    });

    document.querySelectorAll('.reveal-up:not(.is-visible)').forEach(el => observer.observe(el));

    if (window.Shopify && window.Shopify.designMode) {
      document.querySelectorAll('.reveal-up').forEach(el => {
        el.classList.add('is-visible');
      });
    }

    // Accordion Logic
    const questions = document.querySelectorAll('.cbv-faq__question');
    
    questions.forEach(btn => {
      // Remove old listeners to prevent duplicates in Theme Editor
      const newBtn = btn.cloneNode(true);
      btn.parentNode.replaceChild(newBtn, btn);
      
      newBtn.addEventListener('click', function() {
        const item = this.parentElement;
        const answer = this.nextElementSibling;
        const isActive = item.classList.contains('is-active');

        if (isActive) {
          item.classList.remove('is-active');
          this.setAttribute('aria-expanded', 'false');
          answer.style.maxHeight = null;
        } else {
          item.classList.add('is-active');
          this.setAttribute('aria-expanded', 'true');
          answer.style.maxHeight = answer.scrollHeight + "px";
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initFAQ);
  document.addEventListener('shopify:section:load', initFAQ);
</script>

{% schema %}
{
  "name": "FAQ Editorial",
  "settings":[
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#FAF9F6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#2C2C2C"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#A68A6D"
    },
    {
      "type": "color_background",
      "id": "hero_gradient",
      "label": "Hero Background Gradient",
      "default": "linear-gradient(135deg, #F4F0EB 0%, #E3D7C8 100%)"
    },
    {
      "type": "header",
      "content": "Hero Content"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption",
      "default": "Support Center"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How can we help?"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Find quick answers about candles, customization, and subscriptions.</p>"
    },
    {
      "type": "header",
      "content": "Footer CTA"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA Heading",
      "default": "Still need help?"
    },
    {
      "type": "text",
      "id": "cta_button_label",
      "label": "CTA Button",
      "default": "Contact Support"
    },
    {
      "type": "url",
      "id": "cta_button_link",
      "label": "CTA Link"
    }
  ],
  "blocks":[
    {
      "type": "category",
      "name": "Category Heading",
      "settings":[
        {
          "type": "text",
          "id": "title",
          "label": "Category Title",
          "default": "Category Name"
        }
      ]
    },
    {
      "type": "question",
      "name": "Question",
      "settings":[
        {
          "type": "text",
          "id": "title",
          "label": "Question",
          "default": "What is the answer to this question?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>This is the detailed answer to the frequently asked question.</p>"
        }
      ]
    }
  ],
  "presets":[
    {
      "name": "FAQ Editorial"
    }
  ]
}
{% endschema %}