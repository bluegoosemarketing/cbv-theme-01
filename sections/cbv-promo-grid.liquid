{%- style -%}
  .cbv-promos-{{ section.id }} {
    --ink: #2D241E;
    padding: 8rem 5vw;
    background-color: #FFF;
    text-align: center;
  }

  .cbv-promos__title {
    font-family: var(--font-heading-family, 'Playfair Display', serif) !important;
    font-size: clamp(2.8rem, 3vw, 4rem);
    color: var(--ink);
    margin-bottom: 5rem;
    font-weight: 400;
  }

  .cbv-promos__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 3rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .cbv-promo-item {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    group;
  }

  .cbv-promo-item__img-wrapper {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #F9F6F0;
    margin-bottom: 2rem;
  }

  .cbv-promo-item__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .cbv-promo-item:hover .cbv-promo-item__img {
    transform: scale(1.06);
  }

  .cbv-promo-item__text {
    font-family: 'DM Sans', sans-serif !important;
    font-size: 1.6rem;
    color: var(--ink);
    font-weight: 500;
    transition: opacity 0.3s ease;
  }

  .cbv-promo-item:hover .cbv-promo-item__text {
    opacity: 0.7;
  }

  @media screen and (max-width: 990px) {
    .cbv-promos__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }

  @media screen and (max-width: 500px) {
    .cbv-promos__grid {
      grid-template-columns: 1fr;
    }
    .cbv-promos-{{ section.id }} {
      padding: 6rem 5vw;
    }
  }
{%- endstyle -%}

<section class="cbv-promos-{{ section.id }}">
  {%- if section.settings.title != blank -%}
    <h2 class="cbv-promos__title">{{ section.settings.title }}</h2>
  {%- endif -%}

  <div class="cbv-promos__grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link }}" class="cbv-promo-item" {{ block.shopify_attributes }}>
        <div class="cbv-promo-item__img-wrapper">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 600 | image_tag: class: 'cbv-promo-item__img', loading: 'lazy' }}
          {%- else -%}
            <div style="width: 100%; height: 100%; background: #EFE8DF;"></div>
          {%- endif -%}
        </div>
        <span class="cbv-promo-item__text">{{ block.settings.title }}</span>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "CBV Promo Grid",
  "tag": "section",
  "settings":[
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Deals to Inspire You"
    }
  ],
  "blocks":[
    {
      "type": "promo",
      "name": "Promo Item",
      "limit": 4,
      "settings":[
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Promo Title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets":[
    {
      "name": "CBV Promo Grid",
      "blocks":[
        { "type": "promo" },
        { "type": "promo" },
        { "type": "promo" },
        { "type": "promo" }
      ]
    }
  ]
}
{% endschema %}