{{ 'section-cbv-scent-detail.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign scent_name = metaobject.name.value | default: metaobject.name
  assign scent_family = metaobject.scent_family.value | default: metaobject.scent_family
  assign scent_handle = metaobject.handle
  assign scent_description = metaobject.description.value | default: metaobject.description | default: metaobject.short_description.value | default: metaobject.short_description
  assign scent_notes = metaobject.fragrance_notes.value | default: metaobject.fragrance_notes | default: metaobject.notes.value | default: metaobject.notes
  assign scent_season = metaobject.season.value | default: metaobject.season | default: metaobject.seasonal.value | default: metaobject.seasonal
  assign scent_param_value = scent_name | default: scent_handle | strip | url_encode
-%}

<section class="cbv-scent-detail page-width section-{{ section.id }}-padding">
  
  <!-- HERO SECTION -->
  <div class="cbv-scent-hero">
    <!-- Abstract background graphic for texture/luxury feel -->
    <svg class="cbv-hero-bg-graphic" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
      <path fill="currentColor" d="M44.7,-76.4C58.8,-69.2,71.8,-59.1,81.3,-46.1C90.8,-33.1,96.8,-16.6,97.3,-0.1C97.8,16.5,92.8,33,83.3,46C73.8,59,59.8,68.5,44.5,75.2C29.2,81.9,14.6,85.8,0.3,85.3C-14,84.8,-28.1,79.9,-41.8,72.5C-55.5,65.1,-68.9,55.2,-78.6,42.2C-88.3,29.2,-94.3,14.6,-95.2,-0.5C-96.1,-15.6,-91.9,-31.2,-82.1,-43.8C-72.3,-56.4,-56.9,-66,-41.9,-72.7C-26.9,-79.4,-13.4,-83.2,1.2,-85.2C15.8,-87.2,30.6,-83.6,44.7,-76.4Z" transform="translate(100 100)" />
    </svg>

    <div class="cbv-scent-hero__main">
      <span class="cbv-eyebrow">The Fragrance Studio</span>
      <h1 class="cbv-title">{{ scent_name }}</h1>
      <div class="cbv-badges" role="list" aria-label="Scent Details">
        <span class="cbv-badge" role="listitem">{{ scent_family | default: 'Signature Collection' }}</span>
        {%- if scent_season != blank -%}
          <span class="cbv-badge cbv-badge--seasonal" role="listitem">{{ scent_season }}</span>
        {%- endif -%}
      </div>
    </div>

    <div class="cbv-scent-hero__details">
      <div class="cbv-description rte">
        {%- if scent_description != blank -%}
          {{ scent_description }}
        {%- else -%}
          <p>
            A fan-favorite in our {{ scent_family | default: 'signature' }} collection, <strong>{{ scent_name }}</strong> is crafted to deliver a beautiful, room-filling fragrance experience. 
            Select a product format below to begin customizing your perfect pour.
          </p>
        {%- endif -%}
      </div>

      <div class="cbv-facts" aria-label="Fragrance specifications">
        <div class="cbv-fact">
          <span class="cbv-fact-name">Fragrance Family</span>
          <span class="cbv-fact-value">{{ scent_family | default: 'Signature Collection' }}</span>
        </div>
        {%- if scent_notes != blank -%}
          <div class="cbv-fact">
            <span class="cbv-fact-name">Key Notes</span>
            <span class="cbv-fact-value">{{ scent_notes }}</span>
          </div>
        {%- endif -%}
        {%- if scent_season != blank -%}
          <div class="cbv-fact">
            <span class="cbv-fact-name">Seasonal Profile</span>
            <span class="cbv-fact-value">{{ scent_season }}</span>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  <!-- CATEGORIES SECTION -->
  <div class="cbv-formats-wrapper">
    <header class="cbv-formats-header">
      <span class="cbv-eyebrow">Next Step</span>
      <h2>How should we pour {{ scent_name }} for you?</h2>
      <p>Let us know if you're looking for a signature candle, flameless melt, or sampler set. Choose a category below to continue customizing your size.</p>
    </header>

    <div class="cbv-category-grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- liquid
            assign base_url = block.settings.url | default: '/collections/all'
            assign joiner = '?'
            if base_url contains '?'
              assign joiner = '&'
            endif
            
            # This dynamically appends the ?scent=handle to your URL for the next page to read
            assign full_url = base_url | append: joiner | append: 'scent=' | append: scent_param_value
          -%}
          
          <a href="{{ full_url }}" class="cbv-card" {{ block.shopify_attributes }}>
            <div class="cbv-card__top">
              <span class="cbv-card__type">{{ block.settings.tag | default: 'Format' }}</span>
              <h3 class="cbv-card__title">{{ block.settings.title }}</h3>
              <p class="cbv-card__desc">{{ block.settings.subcopy }}</p>
              {%- if block.settings.meta_note != blank -%}
                <span class="cbv-card__meta">{{ block.settings.meta_note }}</span>
              {%- endif -%}
            </div>
            <div class="cbv-card__bottom">
              <span class="cbv-card__cta">{{ block.settings.cta_label | default: 'Select' }} 
                <span class="cbv-card__cta-icon">
                  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </span>
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        <!-- Fallback if blocks are deleted -->
        <a href="/collections/custom-candles?scent={{ scent_param_value }}" class="cbv-card">
          <div class="cbv-card__top">
            <span class="cbv-card__type">Custom Candles</span>
            <h3 class="cbv-card__title">Hand-Poured Candles</h3>
            <p class="cbv-card__desc">Choose from our signature jars and multi-wick centerpieces. Your fragrance will carry over to the next step.</p>
          </div>
          <div class="cbv-card__bottom">
            <span class="cbv-card__cta">Choose Candle Size 
              <span class="cbv-card__cta-icon">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </span>
          </div>
        </a>
      {%- endif -%}
    </div>
  </div>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": {{ scent_name | json }},
      "url": {{ request.origin | append: request.path | json }}
    }
  </script>
</section>

{% schema %}
{
  "name": "CBV Scent Detail",
  "settings":[
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 100
    }
  ],
  "blocks":[
    {
      "type": "format",
      "name": "Category Block",
      "settings":[
        {
          "type": "text",
          "id": "tag",
          "label": "Eyebrow tag",
          "default": "Custom Candles"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category title",
          "default": "Hand-Poured Candles"
        },
        {
          "type": "text",
          "id": "subcopy",
          "label": "Description",
          "default": "Choose from our signature jars and multi-wick centerpieces. Your fragrance will carry over to the next step."
        },
        {
          "type": "url",
          "id": "url",
          "label": "Collection / Link URL"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label",
          "default": "Choose Candle Size"
        },
        {
          "type": "text",
          "id": "meta_note",
          "label": "Optional italic metadata note"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets":[
    {
      "name": "CBV Scent Detail"
    }
  ]
}
{% endschema %}
