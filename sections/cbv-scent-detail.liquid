{{ 'section-cbv-scent-detail.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign scent_name = metaobject.name.value | default: metaobject.name
  assign scent_family = metaobject.scent_family.value | default: metaobject.scent_family
  assign scent_handle = metaobject.handle
  assign scent_description = metaobject.description.value | default: metaobject.description | default: metaobject.short_description.value | default: metaobject.short_description
  assign scent_notes = metaobject.fragrance_notes.value | default: metaobject.fragrance_notes | default: metaobject.notes.value | default: metaobject.notes
  assign scent_season = metaobject.season.value | default: metaobject.season | default: metaobject.seasonal.value | default: metaobject.seasonal

  assign candle_cards = ''
  assign flameless_cards = ''
  assign bundle_cards = ''
-%}

<section class="cbv-scent-detail page-width section-{{ section.id }}-padding">
  
  <!-- HERO SECTION -->
  <div class="cbv-scent-hero">
    <!-- Abstract background graphic for texture/luxury feel -->
    <svg class="cbv-hero-bg-graphic" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
      <path fill="currentColor" d="M44.7,-76.4C58.8,-69.2,71.8,-59.1,81.3,-46.1C90.8,-33.1,96.8,-16.6,97.3,-0.1C97.8,16.5,92.8,33,83.3,46C73.8,59,59.8,68.5,44.5,75.2C29.2,81.9,14.6,85.8,0.3,85.3C-14,84.8,-28.1,79.9,-41.8,72.5C-55.5,65.1,-68.9,55.2,-78.6,42.2C-88.3,29.2,-94.3,14.6,-95.2,-0.5C-96.1,-15.6,-91.9,-31.2,-82.1,-43.8C-72.3,-56.4,-56.9,-66,-41.9,-72.7C-26.9,-79.4,-13.4,-83.2,1.2,-85.2C15.8,-87.2,30.6,-83.6,44.7,-76.4Z" transform="translate(100 100)" />
    </svg>

    <div class="cbv-scent-hero__main">
      <span class="cbv-eyebrow">The Fragrance Studio</span>
      <h1 class="cbv-title">{{ scent_name }}</h1>
      <div class="cbv-badges" role="list" aria-label="Scent Details">
        <span class="cbv-badge" role="listitem">{{ scent_family | default: 'Signature Collection' }}</span>
        {%- if scent_season != blank -%}
          <span class="cbv-badge cbv-badge--seasonal" role="listitem">{{ scent_season }}</span>
        {%- endif -%}
      </div>
    </div>

    <div class="cbv-scent-hero__details">
      <div class="cbv-description rte">
        {%- if scent_description != blank -%}
          {{ scent_description }}
        {%- else -%}
          <p>
            A fan-favorite in our {{ scent_family | default: 'signature' }} collection, <strong>{{ scent_name }}</strong> is crafted to deliver a beautiful, room-filling fragrance experience. 
            Select a format below to begin customizing your perfect pour.
          </p>
        {%- endif -%}
      </div>

      <div class="cbv-facts" aria-label="Fragrance specifications">
        <div class="cbv-fact">
          <span class="cbv-fact-name">Fragrance Family</span>
          <span class="cbv-fact-value">{{ scent_family | default: 'Signature Collection' }}</span>
        </div>
        {%- if scent_notes != blank -%}
          <div class="cbv-fact">
            <span class="cbv-fact-name">Key Notes</span>
            <span class="cbv-fact-value">{{ scent_notes }}</span>
          </div>
        {%- endif -%}
        {%- if scent_season != blank -%}
          <div class="cbv-fact">
            <span class="cbv-fact-name">Seasonal Profile</span>
            <span class="cbv-fact-value">{{ scent_season }}</span>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  <!-- FORMATS SECTION -->
  <div class="cbv-formats-wrapper">
    <header class="cbv-formats-header">
      <span class="cbv-eyebrow">Available Formats</span>
      <h2>Select your vessel</h2>
      <p>From petite everyday pours to dramatic centerpiece vessels, choose your preferred format to enter the studio with <strong>{{ scent_name }}</strong> pre-selected.</p>
    </header>

    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        {%- liquid
          assign base_url = block.settings.product_url | default: '/products/12oz-jar-candle'
          assign joiner = '?'
          if base_url contains '?'
            assign joiner = '&'
          endif
          assign full_url = base_url | append: joiner | append: 'scent=' | append: scent_handle
          
          capture card_markup
            echo '<a href="' | append: full_url | append: '" class="cbv-card" ' | append: block.shopify_attributes | append: '>'
            echo '<div class="cbv-card__top">'
            echo '<span class="cbv-card__type">' | append: block.settings.format_type | default: 'Candle' | append: '</span>'
            echo '<h3 class="cbv-card__title">' | append: block.settings.title | default: 'Builder format' | append: '</h3>'
            echo '<p class="cbv-card__desc">' | append: block.settings.subcopy | default: 'A premium format handcrafted and poured to order.' | append: '</p>'
            if block.settings.wickless_note != blank
              echo '<span class="cbv-card__meta">' | append: block.settings.wickless_note | append: '</span>'
            endif
            echo '</div>'
            echo '<div class="cbv-card__bottom">'
            echo '<span class="cbv-card__cta">' | append: block.settings.cta_label | default: 'Customize' 
            echo '<span class="cbv-card__cta-icon"><svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>'
            echo '</span>'
            echo '</div>'
            echo '</a>'
          endcapture
        -%}
        {%- case block.settings.format_group -%}
          {%- when 'flameless' -%}
            {%- assign flameless_cards = flameless_cards | append: card_markup -%}
          {%- when 'bundle' -%}
            {%- assign bundle_cards = bundle_cards | append: card_markup -%}
          {%- else -%}
            {%- assign candle_cards = candle_cards | append: card_markup -%}
        {%- endcase -%}
      {%- endfor -%}

      <div class="cbv-format-categories">
        {%- if candle_cards != blank -%}
          <section class="cbv-format-category">
            <div class="cbv-category-header">
              <h3 class="cbv-category-title">Signature Candles</h3>
              <div class="cbv-category-line"></div>
            </div>
            <div class="cbv-format-grid">{{ candle_cards }}</div>
          </section>
        {%- endif -%}
        
        {%- if flameless_cards != blank -%}
          <section class="cbv-format-category">
            <div class="cbv-category-header">
              <h3 class="cbv-category-title">Flameless & Wax Melts</h3>
              <div class="cbv-category-line"></div>
            </div>
            <div class="cbv-format-grid">{{ flameless_cards }}</div>
          </section>
        {%- endif -%}
        
        {%- if bundle_cards != blank -%}
          <section class="cbv-format-category">
            <div class="cbv-category-header">
              <h3 class="cbv-category-title">Curated Sets</h3>
              <div class="cbv-category-line"></div>
            </div>
            <div class="cbv-format-grid">{{ bundle_cards }}</div>
          </section>
        {%- endif -%}
      </div>

    {%- else -%}
      <!-- Fallback empty state styling if no blocks -->
      {%- assign fallback_types = '4oz · Mini Jelly|9oz · Salsa / Mini Cylinder|12oz · Tumbler Collection|16oz · Cylinder / Salsa / Square|18oz · Honeycomb Collection|24oz · Ribbed Jar|30oz · Cylinder Statement|70oz · Grand Cylinder' | split: '|' -%}
      {%- assign fallback_titles = '4oz Candle Builder|9oz Candle Builder|12oz Candle Builder|16oz Candle Builder|18oz Candle Builder|24oz Candle Builder|30oz Candle Builder|70oz Candle Builder' | split: '|' -%}
      {%- assign fallback_links = '/collections/candle-jars|/collections/candle-jars|/products/12oz-jar-candle|/products/16oz-square-candle|/products/18oz-honeycomb-candle|/collections/candle-jars|/collections/30oz-victorian|/collections/70oz-5-wick' | split: '|' -%}
      {%- assign fallback_copy = 'Petite one-wick profile with wickless availability for smaller spaces.|Compact one-wick format with wickless availability for desks and bedside styling.|Our signature everyday vessel with curated glass colorways and optional wood wick.|Versatile medium format with curated silhouettes and wickless or wood-wick pathways.|Textural, elevated vessel family with two-wick performance and wickless/wood-wick options.|Ribbed two-wick profile designed for open-concept fragrance moments.|Triple-wick statement format with broad fragrance projection.|Our most dramatic four-wick vessel for large, high-impact spaces.' | split: '|' -%}
      
      <div class="cbv-format-categories">
        <section class="cbv-format-category">
          <div class="cbv-category-header">
            <h3 class="cbv-category-title">Signature Lineup</h3>
            <div class="cbv-category-line"></div>
          </div>
          <div class="cbv-format-grid">
            {%- for item in fallback_titles -%}
              {%- assign idx = forloop.index0 -%}
              {%- assign fallback_url = fallback_links[idx] | append: '?scent=' | append: scent_handle -%}
              <a href="{{ fallback_url }}" class="cbv-card">
                <div class="cbv-card__top">
                  <span class="cbv-card__type">{{ fallback_types[idx] }}</span>
                  <h3 class="cbv-card__title">{{ item }}</h3>
                  <p class="cbv-card__desc">{{ fallback_copy[idx] }}</p>
                </div>
                <div class="cbv-card__bottom">
                  <span class="cbv-card__cta">Customize 
                    <span class="cbv-card__cta-icon"><svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                  </span>
                </div>
              </a>
            {%- endfor -%}
          </div>
        </section>
      </div>
    {%- endif -%}

    <p class="cbv-scent-footnote">Most formats support wickless options. Select vessels offer wood wick upgrades in-builder for a uniquely tailored ambiance.</p>
  </div>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": {{ scent_name | json }},
      "url": {{ request.origin | append: request.path | json }}
    }
  </script>
</section>

{% schema %}
{
  "name": "CBV Scent Detail",
  "settings":[
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 140
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 100
    }
  ],
  "blocks":[
    {
      "type": "format",
      "name": "Format",
      "settings":[
        {
          "type": "select",
          "id": "format_group",
          "label": "Format category",
          "default": "candle",
          "options":[
            {
              "value": "candle",
              "label": "Candles"
            },
            {
              "value": "flameless",
              "label": "Flameless"
            },
            {
              "value": "bundle",
              "label": "Bundles / sets"
            }
          ]
        },
        {
          "type": "text",
          "id": "format_type",
          "label": "Format tag/eyebrow",
          "default": "Candle"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Format title",
          "default": "12oz Jar Candle"
        },
        {
          "type": "text",
          "id": "subcopy",
          "label": "Description",
          "default": "Classic silhouette, double scented, hand-poured in Texas."
        },
        {
          "type": "url",
          "id": "product_url",
          "label": "Product / Builder URL"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label",
          "default": "Customize Scent"
        },
        {
          "type": "text",
          "id": "wickless_note",
          "label": "Optional italic metadata note"
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets":[
    {
      "name": "CBV Scent Detail"
    }
  ]
}
{% endschema %}