{% comment %}
  Section: Policy Editorial
  Description: A premium, split-grid ledger layout for policy pages.
{% endcomment %}

<style>
  /* CSS Reset & Scope Firewall */
  .cbv-policy {
    --color-bg: {{ section.settings.bg_color }};
    --color-text: {{ section.settings.text_color }};
    --color-accent: {{ section.settings.accent_color }};
    --font-heading: var(--font-heading-family, "Playfair Display", Georgia, serif);
    --font-body: var(--font-body-family, "Helvetica Neue", Arial, sans-serif);
    
    background-color: var(--color-bg);
    color: var(--color-text);
    overflow: hidden;
    position: relative;
    font-size: 16px; 
    box-sizing: border-box;
  }

  .cbv-policy * {
    box-sizing: border-box;
  }

  /* Reveal Animations */
  .reveal-up {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .reveal-up.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Typography */
  .cbv-policy h1, .cbv-policy h2, .cbv-policy h3 {
    font-family: var(--font-heading);
    font-weight: 400;
    line-height: 1.15;
    color: currentColor;
    margin: 0 0 24px 0;
  }
  
  .cbv-policy p {
    font-family: var(--font-body);
    line-height: 1.7;
    margin: 0 0 24px 0;
    font-size: clamp(15px, 1.2vw, 17px); 
    letter-spacing: 0.3px;
  }
  .cbv-policy p:last-child { margin-bottom: 0; }

  .cbv-policy a:not(.cbv-btn) {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: var(--color-accent);
    transition: color 0.3s ease;
  }
  .cbv-policy a:not(.cbv-btn):hover {
    color: var(--color-accent);
  }

  .cbv-caption {
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 16px;
    display: block;
    color: var(--color-accent);
  }

  /* Buttons */
  .cbv-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 18px 40px;
    background-color: var(--color-text);
    color: var(--color-bg);
    text-decoration: none !important;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 13px;
    font-weight: 500;
    transition: background-color 0.3s ease, color 0.3s ease;
    border: 1px solid var(--color-text);
    cursor: pointer;
  }
  .cbv-btn:hover {
    background-color: transparent;
    color: var(--color-text);
  }

  /* Hero Section */
  .cbv-policy__hero {
    text-align: center;
    padding: clamp(96px, 10vw, 128px) 32px;
    background: {{ section.settings.hero_gradient }};
  }
  .cbv-policy__hero-inner {
    max-width: 800px;
    margin: 0 auto;
  }
  .cbv-policy__hero h1 {
    font-size: clamp(40px, 5vw, 64px);
    margin-bottom: 24px;
  }

  /* Ledger / Policy Grid Layout */
  .cbv-policy__wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(80px, 8vw, 128px) 32px;
  }

  .cbv-policy__item {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: clamp(40px, 6vw, 96px);
    padding: clamp(48px, 6vw, 80px) 0;
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }
  .cbv-policy__item:first-child {
    border-top: 2px solid var(--color-text);
  }

  .cbv-policy__title-wrapper {
    position: relative;
  }
  .cbv-policy__title {
    position: sticky;
    top: 120px; /* Stays fixed while user reads the right side */
  }
  .cbv-policy__title h2 {
    font-size: clamp(24px, 3vw, 36px);
    margin: 0;
  }

  .cbv-policy__content {
    color: rgba(0,0,0,0.8);
  }
  .cbv-policy__content ul,
  .cbv-policy__content ol {
    margin: 0 0 24px 0;
    padding-left: 24px;
    font-family: var(--font-body);
    font-size: clamp(15px, 1.2vw, 17px);
    line-height: 1.7;
  }
  .cbv-policy__content li {
    margin-bottom: 8px;
  }

  /* Footer CTA */
  .cbv-policy__cta {
    text-align: center;
    padding: clamp(80px, 8vw, 128px) 32px;
    background-color: rgba(0,0,0,0.02);
  }
  .cbv-policy__cta h2 {
    font-size: clamp(32px, 4vw, 48px);
    margin-bottom: 32px;
  }

  /* Responsive Adjustments */
  @media screen and (max-width: 900px) {
    .cbv-policy__item {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 48px 0;
    }
    .cbv-policy__title {
      position: relative;
      top: 0;
    }
  }

  @media screen and (max-width: 600px) {
    .cbv-policy__hero, .cbv-policy__wrapper, .cbv-policy__cta {
      padding-left: 24px;
      padding-right: 24px;
    }
    .cbv-policy__title h2 {
      font-size: 28px;
    }
  }
</style>

<div class="cbv-policy">
  
  <!-- Section Hero -->
  <section class="cbv-policy__hero">
    <div class="cbv-policy__hero-inner reveal-up">
      {% if section.settings.caption != blank %}
        <span class="cbv-caption">{{ section.settings.caption }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h1>{{ section.settings.heading }}</h1>
      {% endif %}
      {% if section.settings.text != blank %}
        <div>{{ section.settings.text }}</div>
      {% endif %}
    </div>
  </section>

  <!-- Ledger Grid Wrapper -->
  <section class="cbv-policy__wrapper">
    {% for block in section.blocks %}
      {% if block.type == 'policy_block' %}
        <div class="cbv-policy__item" {{ block.shopify_attributes }}>
          
          <div class="cbv-policy__title-wrapper">
            <div class="cbv-policy__title reveal-up">
              <h2>{{ block.settings.title }}</h2>
            </div>
          </div>
          
          <div class="cbv-policy__content reveal-up" style="transition-delay: 0.1s;">
            {{ block.settings.text }}
          </div>
          
        </div>
      {% endif %}
    {% endfor %}
  </section>

  <!-- CTA Footer -->
  {% if section.settings.show_cta %}
    <section class="cbv-policy__cta reveal-up">
      <h2>{{ section.settings.cta_heading }}</h2>
      <a href="{{ section.settings.cta_button_link }}" class="cbv-btn">{{ section.settings.cta_button_label }}</a>
    </section>
  {% endif %}

</div>

<script>
  function initPolicyAnimations() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: "0px 0px -50px 0px"
    });

    document.querySelectorAll('.reveal-up:not(.is-visible)').forEach(el => observer.observe(el));

    if (window.Shopify && window.Shopify.designMode) {
      document.querySelectorAll('.reveal-up').forEach(el => {
        el.classList.add('is-visible');
      });
    }
  }

  document.addEventListener('DOMContentLoaded', initPolicyAnimations);
  document.addEventListener('shopify:section:load', initPolicyAnimations);
</script>

{% schema %}
{
  "name": "Policy Editorial",
  "settings":[
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#FAF9F6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#2C2C2C"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#A68A6D"
    },
    {
      "type": "color_background",
      "id": "hero_gradient",
      "label": "Hero Background Gradient",
      "default": "linear-gradient(135deg, #F4F0EB 0%, #E3D7C8 100%)"
    },
    {
      "type": "header",
      "content": "Hero Content"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption",
      "default": "Policy Information"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shipping Policy"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>This page outlines how Candles By Victoria processes, ships, and supports your orders.</p>"
    },
    {
      "type": "header",
      "content": "Footer Support CTA"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show Support CTA",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA Heading",
      "default": "Have a specific question?"
    },
    {
      "type": "text",
      "id": "cta_button_label",
      "label": "CTA Button",
      "default": "Contact Support"
    },
    {
      "type": "url",
      "id": "cta_button_link",
      "label": "CTA Link"
    }
  ],
  "blocks":[
    {
      "type": "policy_block",
      "name": "Policy Section",
      "settings":[
        {
          "type": "text",
          "id": "title",
          "label": "Section Title",
          "default": "Policy Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Policy Text",
          "default": "<p>Details regarding this specific policy.</p>"
        }
      ]
    }
  ],
  "presets":[
    {
      "name": "Policy Editorial"
    }
  ]
}
{% endschema %}