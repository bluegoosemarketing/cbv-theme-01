{%- liquid
  assign scent_library_url = '/pages/scent-library'

  assign scent_family_menu_items = 'рџ§Ѓ Bakery / Gourmand|Bakery||рџЊё Floral & Garden|Floral||рџЌ‹ Fruity & Citrus|Fruity||рџ§ј Clean & Fresh|Clean||рџЊї Earthy & Woody|Earthy||рџЋ„ Holiday & Seasonal|Christmas||рџ’„ Perfume Dupes|Perfume & Cologne||рџЌ№ Tropical|Tropical||рџ§–вЂЌв™ЂпёЏ Luxury Spa|Luxury Spa' | split: '||'
-%}

{%- for item in scent_family_menu_items -%}
  {%- assign parts = item | split: '|' -%}
  {%- assign display_label = parts[0] | strip -%}
  {%- assign canonical_family = parts[1] | strip -%}
  <a
    href="{{ scent_library_url }}?family={{ canonical_family | url_encode }}"
    class="{{ class | default: 'cbv-scent-pill' }}"
    data-scent-family="{{ canonical_family | escape }}"
  >{{ display_label }}</a>
{%- endfor -%}
